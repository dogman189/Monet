{
    "name": "ultraexchange",
    "version": "1.0.0",
    "description": "Algorithmic crypto trading bot — Electron + Python engine",
    "main": "main.js",
    "scripts": {
      "start": "electron .",
      "build": "electron-builder"
    },
    "dependencies": {},
    "devDependencies": {
      "electron": "^30.0.0",
      "electron-builder": "^24.0.0"
    },
    "build": {
      "appId": "com.ultraexchange.app",
      "productName": "ultraexchange",
       "win": {
        "target": {
          "target": "portable",
          "arch": ["x64"]
      }
  },
  "extraResources": [
    {
      "from": "dist/backend.exe",
      "to": "backend.exe"
    }
  ],
  "files": [
    "main.js",
    "preload.js",
    "index.html",
    "renderer.js"
  ]
}
}